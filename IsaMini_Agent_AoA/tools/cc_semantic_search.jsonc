{
  "type": "object",
  "properties": {
    "kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["constant", "lemma", "type", "typeclass", "locale",
                 "introduction rule", "elimination rule"]
      },
      "description": "Entity kinds to search. Use [\"lemma\"] for theorems."
    },
    "query": {
      "type": "string",
      "description": "English description of the entity to search for.",
      "default": ""
    },
    "k": {
      "type": "integer",
      "description": "Number of results to return.",
      "default": 10
    },
    "term_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Constrain lemmas/rules to contain subterms matching each of the patterns. Use _ for wildcard and ?name for named wildcards (example: ?P ⟶ ?Q ⟶ ?P ∧ ?Q).",
      "default": []
    },
    "type_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Constrain results to involve types matching the patterns. Use _ for wildcard and ?name for named wildcards.",
      "default": []
    },
    "theories_include": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Constrain results to the given theories (short or full names).",
      "default": []
    }
  },
  "required": ["kinds"],
  "additionalProperties": false
}
