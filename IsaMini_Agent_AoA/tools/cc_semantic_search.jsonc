{
  "type": "object",
  "properties": {
    "queries": {
      "type": "array",
      "minItems": 1,
      "description": "Batch queries together whenever possible.",
      "items": {
        "type": "object",
        "properties": {
          "kinds": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["constant", "lemma", "type", "typeclass", "locale",
                       "introduction rule", "elimination rule",
                       "induction rule", "case-split rule"]
            }
          },
          "long_description": {
            "type": "string",
            "description": "MUST wrap formulas in backticks (like `ln 1`). MUST be LONG",
            "default": ""
          },
          "term_patterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Constrain lemmas/rules to contain subterms matching each of the patterns. Use _ for wildcard and ?name for named wildcards (example: ?P ⟶ ?Q ⟶ ?P ∧ ?Q).",
            "default": []
          },
          "type_patterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Constrain results to involve types matching the patterns. Use _ for wildcard and ?name for named wildcards.",
            "default": []
          },
          "theories_include": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Constrain results to the given theories (short or full names).",
            "default": []
          },
          "name_contains": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Constrain entities' names to contain all of these substrings (case-insensitive).",
            "default": []
          },
          "exact_name": {
            "type": "string",
            "description": "Look up an entity by its exact short or full name. When given, all other search criteria are ignored."
          },
          "exact_term": {
            "type": "string",
            "description": "Parse a term, show its unfolded lambda structure (Main-level syntax only), and look up the head constant. When given, all other fields are ignored."
          }
        },
        "required": [],
        "additionalProperties": false
      }
    }
  },
  "required": ["queries"],
  "additionalProperties": false
}
