{
  "$defs": {
    "Thought": {
      "description": "A brief thought that justifies the chosen operation",
      "type": "string"
    },
    "Variable": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "Variable",
      "type": "object"
    },
    "Statement": {
      "title": "Statement",
      "properties": {
        "english": {
          "type": "string",
          "description": "the natural language statement in English"
        },
        "isabelle": {
          "type": "string",
          "description": "the formal statement in Isabelle/HOL"
        }
      },
      "required": [
        "english",
        "isabelle"
      ],
      "type": "object",
      "additionalProperties": false
    },
    "FactByName": {
      "title": "FactByName",
      "additionalProperties": false,
      "properties": {
        "refer_by": {
          "type": "string",
          "const": "name"
        },
        "name": { "type": "string" }
      },
      "required": [ "refer_by", "name" ],
      "type": "object"
    },
    "FactByExpr": {
      "title": "FactByExpr",
      "additionalProperties": false,
      "properties": {
        "refer_by": {
          "type": "string",
          "const": "expr"
        },
        "english": {
          "description": "natural language description of the fact",
          "type": "string"
        },
        "isabelle_expression": {
          "description": "Isabelle/HOL expression of the fact",
          "type": "string"
        }
        // "for_any": {
        //   "default": [],
        //   "description": "variables that the fact is universally quantified over",
        //   "items": {
        //     "anyOf": [
        //       { "$ref": "#/$defs/Variable" },
        //       { "type": "string" }
        //     ]
        //   },
        //   "type": "array"
        // }
      },
      "required": [
        "refer_by",
        "english",
        "isabelle_expression"
      ],
      "type": "object"
    },
    "Fact": {
      "anyOf": [
        { "$ref": "#/$defs/FactByName" },
        { "$ref": "#/$defs/FactByExpr" }
      ]
    },

    "Obvious": {
      "additionalProperties": false,
      "title": "Obvious",
      "description": "the goal holds trivially",
      "properties": {
        "operation": {
          "const": "Obvious",
          "type": "string"
        },
        "thought": {"$ref": "#/$defs/Thought" },
        "facts": {
          "description": "helpful facts for proving the goal",
          "items": { "$ref": "#/$defs/Fact" },
          "type": "array"
        }
      },
      "required": [
        "operation",
        "thought",
        "facts"
      ],
      "type": "object"
    },
    "Have": {
      "additionalProperties": false,
      "title": "Have",
      "description": "prove a lemma",
      "properties": {
        "operation": {
          "const": "Have",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "statement": { "$ref": "#/$defs/Statement" },
        "name": { "type": "string", "description": "binding of the lemma" }
      },
      "required": [
        "operation",
        "thought",
        "statement",
        "name"
      ],
      "type": "object"
    },
    "Obtain": {
      "additionalProperties": false,
      "title": "Obtain",
      "description": "introduce variables satisfying given constraints",
      "properties": {
        "operation": {
          "const": "obtain",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "variables": {
          "description": "fresh variables to introduce; no conflict with existing variables",
          "items": { "$ref": "#/$defs/Variable" },
          "type": "array"
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/Statement" }
        }
      },
      "required": [
        "operation",
        "thought",
        "variables",
        "constraints"
      ],
      "type": "object"
    },
    "Branch": {
      "additionalProperties": false,
      "title": "Branch",
      "description": "split the proof goal into cases",
      "properties": {
        "operation": {
          "const": "Branch",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "cases": {
          "items": { "$ref": "#/$defs/Statement" },
          "type": "array"
        }
      },
      "required": [
        "operation",
        "thought",
        "cases"
      ],
      "type": "object"
    },
    "CaseSplit": {
      "additionalProperties": false,
      "title": "CaseSplit",
      "description": "structural case analysis on the value of a target term",
      "properties": {
        "operation": {
          "const": "CaseSplit",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "target_isabelle_term": { "type": "string" }
      },
      "required": [
        "operation",
        "thought",
        "target_isabelle_term"
      ],
      "type": "object"
    },
    "Induction": {
      "additionalProperties": false,
      "title": "Induction",
      "description": "apply induction over the target Isabelle/HOL term",
      "properties": {
        "operation": {
          "const": "Induction",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "target_isabelle_term": { "type": "string" },
        "rule": {
          "description": "how the induction should work",
          "anyOf": [
            {
              "type": "string",
              "enum": [ "default", "reversely" ]
            },
            {
              "type": "object",
              "description": "perform ascending or descending induction from an optional start to an optional end",
              "properties": {
                "rule": {
                  "type": "string",
                  "enum": [ "ascending", "descending" ]
                },
                "start": {
                  "type": "string",
                  "description": "lower bound if ascending, or upper bound if descending. Omit to indicate no bound (negative or positive infinity)"
                },
                "end": {
                  "type": "string",
                  "description": "upper bound if ascending, or lower bound if descending. Omit to indicate no bound (positive or negative infinity)"
                }
              },
              "required": [
                "rule"
              ]
            },
            {
              "type": "string",
              "description": "any other rule described in English"
            }
          ],
          "default": "default"
        },
        "variables": {
          "description": "for each variable in the context, indicate whether it is fixed or generalized (universally quantified) across the induction",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "status": { "type": "string", "enum": [ "fixed", "generalized" ] }
            },
            "required": [ "name", "status" ]
          },
          "type": "array"
        }
      },
      "required": [
        "operation",
        "thought",
        "target_isabelle_term",
        "variables"
      ],
      "type": "object"
    },
    "InferenceRule": {
      "title": "InferenceRule",
      "additionalProperties": false,
      "description": "instruct an inference rule, e.g., proof by contradiction, or proving equality by antisymmetry.",
      "properties": {
        "operation": {
          "const": "InferenceRule",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        // TODO: add common rules like proof by contradiction, proving equality by antisymmetry, etc.
        "rule": { "$ref": "#/$defs/Fact" }
      },
      "required": [
        "operation",
        "thought",
        "rule"
      ],
      "type": "object"
    },
    "Rewrite": {
      "additionalProperties": false,
      "description": "rewrite goals and premises using equations, established facts, and system simplifiers",
      "properties": {
        "operation": {
          "const": "Rewrite",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "using": {
          "description": "equations and facts to use for rewriting",
          "items": { "$ref": "#/$defs/Fact" },
          "type": "array"
        },
        "use system simplifiers": {
          "type": "boolean",
          "default": true
        },
        "rewrite goal": {
          "type": "boolean",
          "default": true
        },
        "rewrite premises": {
          "type": "array",
          "items": { "type": "string" },
          "description": "names of premises to rewrite"
        }
      },
      "required": [
        "operation",
        "thought",
        "using",
        "use system simplifiers",
        "rewrite goal",
        "rewrite premises"
      ],
      "title": "Rewrite",
      "type": "object"
    },
    "Suffices": {
      "additionalProperties": false,
      "description": "to establish the current goal, it suffices to show an equivalent or stronger statement",
      "properties": {
        "operation": {
          "const": "Suffices",
          "type": "string"
        },
        "thought": {
          "$ref": "#/$defs/Thought"
        },
        "statement": {
          "$ref": "#/$defs/Statement"
        }
      },
      "required": [
        "operation",
        "thought",
        "statement"
      ],
      "type": "object"
    },
    "Unfold": {
      "additionalProperties": false,
      "description": "unfold definitions",
      "properties": {
        "operation": {
          "const": "Unfold",
          "title": "Operation",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "targets": {
          "description": "the target Isabelle/HOL terms to unfold",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "operation",
        "thought",
        "targets"
      ],
      "title": "Unfold",
      "type": "object"
    },
    "Witness": {
      "additionalProperties": false,
      "description": "provide a witness to reduce a existential proof goal",
      "properties": {
        "operation": {
          "const": "Witness",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "witness": {
          "description": "an Isabelle/HOL term",
          "type": "string"
        }
      },
      "required": [
        "operation",
        "thought",
        "witness"
      ],
      "title": "Witness",
      "type": "object"
    },
    "Operation": {
      "anyOf": [
        { "$ref": "#/$defs/Obvious" },
        { "$ref": "#/$defs/Have" },
        { "$ref": "#/$defs/Obtain" },
        { "$ref": "#/$defs/Branch" },
        { "$ref": "#/$defs/CaseSplit" },
        { "$ref": "#/$defs/Induction" },
        { "$ref": "#/$defs/Rewrite" },
        { "$ref": "#/$defs/Unfold" },
        { "$ref": "#/$defs/Witness" },
        { "$ref": "#/$defs/InferenceRule" },
        { "$ref": "#/$defs/Suffices" }
      ]
    }
  },
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "fill",
        "insert_before",
        "amend",
        "delete",
        "delete_all_after"
      ],
      "description": "fill: fill a proof operation into a blank; insert_before: insert a step before the target step; amend: modify the arguments of the target step; delete: delete the target step and all its sub-steps, delete_all_after: delete the target step, all its sub-steps, and all steps after it"
    },
    "target_step": {
      "type": "string",
      "description": "id of the target step"
    },
    "proof_operation": { "$ref": "#/$defs/Operation" }
  },
  "required": [
    "action",
    "target_step",
    "proof_operation"
  ],
  "additionalProperties": false
}