{
  "$defs": {
    "Thought": {
      "description": "A brief thought that justifies the chosen operation",
      "type": "string"
    },
    "Variable": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string",
          "description": "An Isabelle type expression. Leave empty (\"\") if unsure"
        }
      },
      "required": [
        "name"
      ],
      "title": "Variable",
      "type": "object"
    },
    "Statement": {
      "title": "Statement",
      "properties": {
        "english": {
          "type": "string",
          "description": "the statement in English"
        },
        "isabelle": {
          "type": "string",
          "description": "the corresponding Isabelle/HOL statement"
        }
      },
      "required": [
        "english",
        "isabelle"
      ],
      "type": "object",
      "additionalProperties": false
    },
    "NamedStatement": {
      "title": "NamedStatement",
      "properties": {
        "english": {
          "type": "string",
          "description": "the statement in English"
        },
        "isabelle": {
          "type": "string",
          "description": "the corresponding Isabelle/HOL statement"
        },
        "name": {
          "type": "string",
          "description": "optional binding name"
        }
      },
      "required": ["english", "isabelle"],
      "type": "object",
      "additionalProperties": false
    },
    "FactByName": {
      "title": "FactByName",
      "additionalProperties": false,
      "properties": {
        "refer_by": {
          "type": "string",
          "const": "name"
        },
        "name": {
          "type": "string",
          "description": "the exact name of the fact in Isabelle/HOL"
        }
      },
      "required": [ "refer_by", "name" ],
      "type": "object"
    },
    "FactByProposition": {
      "title": "FactByProposition",
      "additionalProperties": false,
      "properties": {
        "refer_by": {
          "type": "string",
          "const": "proposition"
        },
        "proposition": {
          "description": "a formal Isabelle/HOL proposition to be proven in time. IMPORTANT: all numeric literals MUST be type-annotated, example: `(2::nat)` not `2`",
          "type": "string"
        }
      },
      "required": [
        "refer_by",
        "proposition"
      ],
      "type": "object"
    },
    "FactByDescription": {
      "title": "FactByDescription",
      "additionalProperties": false,
      "properties": {
        "refer_by": {
          "type": "string",
          "const": "description"
        },
        "english": {
          "description": "an English description of the fact to search for",
          "type": "string"
        }
      },
      "required": [
        "refer_by",
        "english"
      ],
      "type": "object"
    },
    "SubProof": {
      "anyOf": [
        { "$ref": "#/$defs/Obvious" },
        { "const": "Given later" }
      ]
    },

    "Obvious": {
      "additionalProperties": false,
      "title": "Obvious",
      "description": "the goal holds trivially. Caution: this operation barely unfolds definitions unless you supply them in `facts`. This operation is SLOW!",
      "properties": {
        "operation": {
          "const": "Obvious",
          "type": "string"
        },
        "facts": {
          "description": "helpful facts for proving the goal",
          "items": {
            "anyOf": [
              { "$ref": "#/$defs/FactByName" },
              { "$ref": "#/$defs/FactByProposition" }
            ]
          },
          "type": "array"
        }
      },
      "required": [
        "operation",
        "facts"
      ],
      "type": "object"
    },
    "Have": {
      "additionalProperties": false,
      "title": "Have",
      "description": "prove a lemma",
      "properties": {
        "operation": {
          "const": "Have",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "statement": { "$ref": "#/$defs/Statement" },
        "name": { "type": "string", "description": "binding of the lemma" },
        "proof": { "$ref": "#/$defs/SubProof" },
        "auto_apply": {
          "type": "boolean",
          "default": false,
          "description": "if turned on, the proven statement will applied automatically by the system simplifier and reasoner"
        }
      },
      "required": [
        "operation",
        "thought",
        "statement",
        "name",
        "proof"
      ],
      "type": "object"
    },
    "Obtain": {
      "additionalProperties": false,
      "title": "Obtain",
      "description": "introduce variables satisfying given constraints",
      "properties": {
        "operation": {
          "const": "Obtain",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "variables": {
          "description": "fresh variables to introduce; no conflict with existing variables",
          "items": { "$ref": "#/$defs/Variable" },
          "type": "array"
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamedStatement" }
        },
        "proof": { "$ref": "#/$defs/SubProof" }
      },
      "required": [
        "operation",
        "thought",
        "variables",
        "constraints",
        "proof"
      ],
      "type": "object"
    },
    "Branch": {
      "additionalProperties": false,
      "title": "Branch",
      "description": "split the proof goal into cases",
      "properties": {
        "operation": {
          "const": "Branch",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "cases": {
          "items": {
            "type": "object",
            "properties": {
              "statement": { "$ref": "#/$defs/NamedStatement" },
              "proof": { "$ref": "#/$defs/SubProof" }
            },
            "required": [ "statement", "proof" ]
          },
          "type": "array"
        }
      },
      "required": [
        "operation",
        "thought",
        "cases"
      ],
      "type": "object"
    },
    "CaseSplit": {
      "additionalProperties": false,
      "title": "CaseSplit",
      "description": "structural case analysis on the value of a target term",
      "properties": {
        "operation": {
          "const": "CaseSplit",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "target_isabelle_term": { "type": "string" },
        "proof": { "$ref": "#/$defs/SubProof" }
      },
      "required": [
        "operation",
        "thought",
        "target_isabelle_term",
        "proof"
      ],
      "type": "object"
    },
    "Induction": {
      "additionalProperties": false,
      "title": "Induction",
      "description": "apply induction over the target Isabelle/HOL term",
      "properties": {
        "operation": {
          "const": "Induction",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "target_isabelle_term": { "type": "string" },
        "rule": {
          "description": "how the induction should work",
          "anyOf": [
            {
              "type": "string",
              "enum": [ "default", "reversely" ]
            },
            {
              "type": "object",
              "description": "perform ascending or descending induction from an optional start to an optional end",
              "properties": {
                "rule": {
                  "type": "string",
                  "enum": [ "ascending", "descending" ]
                },
                "start": {
                  "type": "string",
                  "description": "lower bound if ascending, or upper bound if descending. Omit to indicate no bound (negative or positive infinity)"
                },
                "end": {
                  "type": "string",
                  "description": "upper bound if ascending, or lower bound if descending. Omit to indicate no bound (positive or negative infinity)"
                }
              },
              "required": [
                "rule"
              ]
            },
            {
              "type": "string",
              "description": "any other rule described in English"
            }
          ],
          "default": "default"
        },
        "variables": {
          "description": "for each variable in the context, indicate whether it is fixed or generalized (universally quantified) across the induction",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "status": { "type": "string", "enum": [ "fixed", "generalized" ] }
            },
            "required": [ "name", "status" ]
          },
          "type": "array"
        },
        "proof": { "$ref": "#/$defs/SubProof" }
      },
      "required": [
        "operation",
        "thought",
        "target_isabelle_term",
        "variables",
        "proof"
      ],
      "type": "object"
    },
    "InferenceRule": {
      "title": "InferenceRule",
      "additionalProperties": false,
      "description": "instruct an inference rule, e.g., proof by contradiction, or proving equality by antisymmetry.",
      "properties": {
        "operation": {
          "const": "InferenceRule",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        // TODO: add common rules like proof by contradiction, proving equality by antisymmetry, etc.
        "rule": {
          "anyOf": [
            { "$ref": "#/$defs/FactByName" },
            { "$ref": "#/$defs/FactByDescription" }
          ]
        }
      },
      "required": [
        "operation",
        "thought",
        "rule"
      ],
      "type": "object"
    },
    "Rewrite": {
      "additionalProperties": false,
      "description": "rewrite goals and premises using equations, established facts, and system simplifiers",
      "properties": {
        "operation": {
          "const": "Rewrite",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "using": {
          "description": "equations and facts to use for rewriting",
          "items": {
            "anyOf": [
              { "$ref": "#/$defs/FactByName" },
              { "$ref": "#/$defs/FactByProposition" }
            ]
          },
          "type": "array"
        },
        "use system simplifiers": {
          "type": "boolean",
          "default": true
        },
        "rewrite goal": {
          "type": "boolean",
          "default": true
        },
        "rewrite premises": {
          "type": "array",
          "items": { "type": "string" },
          "description": "names of premises to rewrite"
        }
      },
      "required": [
        "operation",
        "thought",
        "using",
        "use system simplifiers",
        "rewrite goal",
        "rewrite premises"
      ],
      "title": "Rewrite",
      "type": "object"
    },
    "Suffices": {
      "additionalProperties": false,
      "description": "to establish the current goal, it suffices to show an equivalent or stronger statement",
      "properties": {
        "operation": {
          "const": "Suffices",
          "type": "string"
        },
        "thought": {
          "$ref": "#/$defs/Thought"
        },
        "statement": {
          "$ref": "#/$defs/Statement"
        },
        "proof": { "$ref": "#/$defs/SubProof" }
      },
      "required": [
        "operation",
        "thought",
        "statement",
        "proof"
      ],
      "type": "object"
    },
    "Unfold": {
      "additionalProperties": false,
      "description": "unfold definitions",
      "properties": {
        "operation": {
          "const": "Unfold",
          "title": "Operation",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "targets": {
          "description": "the target Isabelle/HOL terms to unfold",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "operation",
        "thought",
        "targets"
      ],
      "title": "Unfold",
      "type": "object"
    },
    "Witness": {
      "additionalProperties": false,
      "description": "provide a witness to reduce a existential proof goal",
      "properties": {
        "operation": {
          "const": "Witness",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "witness": {
          "description": "an Isabelle/HOL term",
          "type": "string"
        }
      },
      "required": [
        "operation",
        "thought",
        "witness"
      ],
      "title": "Witness",
      "type": "object"
    },
    "Intro": {
      "additionalProperties": false,
      "title": "Intro",
      "description": "introduce universal quantification and premises from the proof goal; can also split conjunctions into subgoals",
      "properties": {
        "operation": {
          "const": "Intro",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "variable_bindings": {
          "description": "names to bind to the universally quantified variables, in order",
          "items": { "type": "string" },
          "type": "array"
        },
        "fact_bindings": {
          "description": "names to bind to the premises, in order",
          "items": { "type": "string" },
          "type": "array"
        },
        "split_conj": {
          "type": "boolean",
          "default": false,
          "description": "whether to split conjunctions in the goal after introduction"
        }
      },
      "required": [
        "operation",
        "thought"
      ],
      "type": "object"
    },
    "Instantiation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "value": {
          "type": "string",
          "description": "Isabelle/HOL term to substitute"
        }
      },
      "required": ["name", "value"]
    },
    "Derive": {
      "additionalProperties": false,
      "title": "Derive",
      "description": "instantiate universal quantifiers in a rule and discharge its premises, deriving a new fact in one forward-reasoning step",
      "properties": {
        "operation": {
          "const": "Derive",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "rule": {
          "$ref": "#/$defs/FactByName",
          "description": "the rule or theorem to specialize"
        },
        "instantiations": {
          "description": "instantiations for ∀-quantified or schematic variables",
          "items": { "$ref": "#/$defs/Instantiation" },
          "type": "array",
          "default": []
        },
        "discharging_facts": {
          "description": "facts discharging the premises of the rule, left-to-right",
          "items": { "$ref": "#/$defs/FactByName" },
          "type": "array",
          "default": []
        },
        "result_name": {
          "type": "string",
          "description": "name to bind the resulting derived fact under"
        }
      },
      "required": [
        "operation",
        "thought",
        "rule",
        "result_name"
      ],
      "type": "object"
    },
    "Chaining": {
      "additionalProperties": false,
      "title": "Chaining",
      "description": "chain facts via transitivity (example: deriving a \u2264 c from a = b, b \u2264 c)",
      "properties": {
        "operation": {
          "const": "Chaining",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "name": {
          "type": "string",
          "description": "binding name for the chained result"
        },
        "facts": {
          "items": {
            "anyOf": [
              { "$ref": "#/$defs/FactByName" },
              { "$ref": "#/$defs/FactByProposition" }
            ]
          },
          "type": "array",
          "minItems": 1
        }
      },
      "required": [
        "operation",
        "thought",
        "facts"
      ],
      "type": "object"
    },
    "Define": {
      "additionalProperties": false,
      "title": "Function",
      "description": "define a (recursive) function",
      "properties": {
        "operation": {
          "const": "Define",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "description": "Isabelle type expression"
        },
        "equations": {
          "items": {
            "type": "string",
            "description": "Isabelle term"
          },
          "type": "array"
        }
      }
    },
    "Operation": {
      "anyOf": [
        { "$ref": "#/$defs/Obvious" },
        { "$ref": "#/$defs/Have" },
        { "$ref": "#/$defs/Obtain" },
        { "$ref": "#/$defs/Branch" },
        { "$ref": "#/$defs/CaseSplit" },
        { "$ref": "#/$defs/Induction" },
        { "$ref": "#/$defs/Rewrite" },
        { "$ref": "#/$defs/Unfold" },
        { "$ref": "#/$defs/Witness" },
        { "$ref": "#/$defs/InferenceRule" },
        { "$ref": "#/$defs/Suffices" },
        { "$ref": "#/$defs/Intro" },
        { "$ref": "#/$defs/Derive" },
        { "$ref": "#/$defs/Chaining" }
      ]
    }
  },
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "fill",
        "insert_before",
        "amend"
      ],
      "description": "fill: fill a proof operation into a blank; insert_before: insert a step before the target step; amend: modify the arguments of the target step"
    },
    "target_step": {
      "type": "string",
      "description": "id of the target step"
    },
    "proof_operation": { "$ref": "#/$defs/Operation" }
  },
  "required": [
    "action",
    "target_step",
    "proof_operation"
  ],
  "additionalProperties": false
}