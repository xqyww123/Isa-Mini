# Copy this file to .env and fill in the values as needed.

# Required for Gemini via LangChain (google_genai) and the Gemini Python client
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here


# ------------------------------------------------------------
# LLM pricing (per 1K tokens) for usage reporting
# Set these to enable estimated cost output in the LangChain driver.
#
# Gemini 2.5 Pro (prompts <= 200k tokens):
#   Input $1.25 / 1M  -> 0.00125 per 1K
#   Output $10.00 / 1M -> 0.01 per 1K
GEMINI_INPUT_PRICE_PER_1K=0.00125
GEMINI_OUTPUT_PRICE_PER_1K=0.01

# Alternatives:
# Gemini 2.5 Pro (prompts > 200k tokens):
# GEMINI_INPUT_PRICE_PER_1K=0.0025
# GEMINI_OUTPUT_PRICE_PER_1K=0.015

# Gemini 2.5 Flash (text):
# GEMINI_INPUT_PRICE_PER_1K=0.00030
# GEMINI_OUTPUT_PRICE_PER_1K=0.0025