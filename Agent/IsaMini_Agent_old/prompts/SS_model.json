{
  "$defs": {
    "Branch": {
      "additionalProperties": false,
      "title": "Branch",
      "description": "Split the proof goal into cases",
      "properties": {
        "operation": {
          "const": "Branch",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "cases": {
          "items": { "$ref": "#/$defs/Statement" },
          "type": "array"
        },
        "next_step": { "$ref": "#/$defs/Must_Yield" }
      },
      "required": [
        "operation",
        "thought",
        "cases",
        "next_step"
      ],
      "type": "object"
    },
    "CaseAnalysis": {
      "additionalProperties": false,
      "title": "CaseAnalysis",
      "description": "Structural case analysis on the value of a target term",
      "properties": {
        "operation": {
          "const": "CaseAnalysis",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "target_isabelle_term": { "type": "string" },
        "next_step": { "$ref": "#/$defs/Must_Yield" }
      },
      "required": [
        "operation",
        "thought",
        "target_isabelle_term",
        "next_step"
      ],
      "type": "object"
    },
    "Fact": {
      "title": "Fact",
      "additionalProperties": false,
      "properties": {
        "english": {
          "description": "the natural language description of the fact",
          "type": "string"
        },
        "isabelle_expression": {
          "description": "the Isabelle/HOL expression of the fact",
          "type": "string"
        },
        "for_any": {
          "default": [],
          "description": "variables that the fact is universally quantified over",
          "items": {
            "anyOf": [
              { "$ref": "#/$defs/Variable" },
              { "type": "string" }
            ]
          },
          "type": "array"
        }
      },
      "required": [
        "english",
        "isabelle_expression"
      ],
      "type": "object"
    },
    "Have": {
      "additionalProperties": false,
      "title": "Have",
      "description": "Introduce a subgoal",
      "properties": {
        "operation": {
          "const": "Have",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "statement": { "$ref": "#/$defs/Statement" },
        "next_step": { "$ref": "#/$defs/Next_Step" }
      },
      "required": [
        "operation",
        "thought",
        "statement",
        "next_step"
      ],
      "type": "object"
    },
    "Induction": {
      "additionalProperties": false,
      "title": "Induction",
      "description": "Apply induction over the target Isabelle/HOL term",
      "properties": {
        "operation": {
          "const": "induction",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "target_isabelle_term": { "type": "string" },
        "rule": {
          "description": "How the induction should work",
          "anyOf": [
            { "type": "string",
              "enum": [
                "default",
                "reversely"]},
            { "type": "object",
              "description": "Induct increasingly from an optional lower bound to an optional upper bound",
              "properties": {
                "rule": { "type": "string", "const": "increase" },
                "from": { "type": "string",
                  "description": "lower bound. Omit if no bound (negative infinity)"
                },
                "to": { "type": "string",
                  "description": "upper bound. Omit if no bound (positive infinity)"
                },
                "required": ["rule"]
            }},
            { "type": "object",
              "description": "Induct decreasingly from an optional upper bound to an optional lower bound",
              "properties": {
                "rule": { "type": "string", "const": "decrease" },
                "from": { "type": "string",
                  "description": "upper bound. Omit if no bound (positive infinity)"
                },
                "to": { "type": "string",
                  "description": "lower bound. Omit if no bound (negative infinity)"
                },
                "required": ["rule"]
            }},
            {"type": "string",
            "description": "Any other rule described in English" }
          ],
          "default": "default"
        },
        "variables": {
          "description": "List all variables in the proof goal and indicate whether their values vary or are fixed throughout the induction",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "varying": { "type": "boolean" }
            },
            "required": ["name", "varying"]
          },
          "type": "array"
        },
        "next_step": { "$ref": "#/$defs/Must_Yield" }
      },
      "required": [
        "operation",
        "thought",
        "target_isabelle_term",
        "variables",
        "next_step"
      ],
      "type": "object"
    },
    "InferenceRule": {
      "title": "InferenceRule",
      "additionalProperties": false,
      "description": "Prove using a specific inference rule, e.g., contradiction, or proving equality by antisymmetry.",
      "properties": {
        "operation": {
          "const": "InferenceRule",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "rule": { "$ref": "#/$defs/Fact" },
        "next_step": { "$ref": "#/$defs/Must_Yield" }
      },
      "required": [
        "operation",
        "thought",
        "rule",
        "next_step"
      ],
      "type": "object"
    },
    "Obtain": {
      "additionalProperties": false,
      "title": "Obtain",
      "description": "Introduce variables satisfying the given constraints",
      "properties": {
        "operation": {
          "const": "obtain",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "variables": {
          "description": "The variables to introduce. Do not write existing variables",
          "items": { "$ref": "#/$defs/Variable" },
          "type": "array"
        },
        "constraints": {
          "items": { "$ref": "#/$defs/Statement" },
          "type": "array"
        },
        "next_step": {"$ref": "#/$defs/Next_Step"}
      },
      "required": [
        "operation",
        "thought",
        "variables",
        "constraints",
        "next_step"
      ],
      "type": "object"
    },
    "Rewrite": {
      "additionalProperties": false,
      "description": "Rewrite proof goals using equations",
      "properties": {
        "operation": {
          "const": "rewrite",
          "type": "string"
        },
        "thought": { "$ref": "#/$defs/Thought" },
        "equations": {
          "description": "equations to use, which might be conditioned",
          "items": {
            "$ref": "#/$defs/Fact"
          },
          "type": "array"
        },
        "lemmas": {
          "description": "lemmas for solving the conditions",
          "items": {
            "$ref": "#/$defs/Fact"
          },
          "type": "array"
        },
        "next_step": {"$ref": "#/$defs/Must_Yield"}
      },
      "required": [
        "operation",
        "thought",
        "equations",
        "next_step"
      ],
      "title": "Rewrite",
      "type": "object"
    },
    "Statement": {
      "title": "Statement",
      "properties": {
        "english": {
          "description": "the natural language statement in English",
          "type": "string"
        },
        "isabelle": {
          "description": "the formal statement in Isabelle/HOL",
          "type": "string"
        }
      },
      "required": [
        "english",
        "isabelle"
      ],
      "type": "object",
      "additionalProperties": false
    },
    "Suffices_to_Show": {
      "additionalProperties": false,
      "description": "to establish the current goal, it suffices to show a stronger or equivalent statement",
      "properties": {
        "operation": {
          "const": "suffices_to_show",
          "title": "Operation",
          "type": "string"
        },
        "thought": {
          "description": "a brief thought that justifies the chosen operation",
          "title": "Thought",
          "type": "string"
        },
        "statement": {
          "$ref": "#/$defs/Statement"
        },
        "next_step": { "$ref": "#/$defs/Next_Step" }
      },
      "required": [
        "operation",
        "thought",
        "statement",
        "next_step"
      ],
      "title": "Suffices to Show",
      "type": "object"
    },
    "Unfold": {
      "additionalProperties": false,
      "description": "unfold definitions",
      "properties": {
        "operation": {
          "const": "unfold",
          "title": "Operation",
          "type": "string"
        },
        "thought": {
          "description": "a brief thought that justifies the chosen operation",
          "title": "Thought",
          "type": "string"
        },
        "targets": {
          "description": "the target Isabelle/HOL terms to unfold",
          "items": {
            "type": "string"
          },
          "title": "Targets",
          "type": "array"
        },
        "next_step": { "$ref": "#/$defs/Must_Yield" }
      },
      "required": [
        "operation",
        "thought",
        "targets",
        "next_step"
      ],
      "title": "Unfold",
      "type": "object"
    },
    "Variable": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "default": "",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "Variable",
      "type": "object"
    },
    "Witness": {
      "additionalProperties": false,
      "description": "provide witnesses to reduce existential proof goals. You still need to prove the goal instantiated with the witnesses later.",
      "properties": {
        "operation": {
          "const": "witness",
          "title": "Operation",
          "type": "string"
        },
        "thought": {
          "description": "a brief thought that justifies the chosen operation",
          "title": "Thought",
          "type": "string"
        },
        "witnesses": {
          "description": "Isabelle/HOL expressions of the witness terms",
          "items": {
            "type": "string"
          },
          "title": "Witnesses",
          "type": "array"
        },
        "next_step": { "$ref": "#/$defs/Next_Step" }
      },
      "required": [
        "operation",
        "thought",
        "witnesses",
        "next_step"
      ],
      "title": "Witness",
      "type": "object"
    },
    "Operation": {
      "anyOf": [
        { "$ref": "#/$defs/Have" },
        { "$ref": "#/$defs/Obtain" },
        { "$ref": "#/$defs/Branch" },
        { "$ref": "#/$defs/CaseAnalysis" },
        { "$ref": "#/$defs/Induction" },
        { "$ref": "#/$defs/Rewrite" },
        { "$ref": "#/$defs/Unfold" },
        { "$ref": "#/$defs/Witness" },
        { "$ref": "#/$defs/InferenceRule" },
        { "$ref": "#/$defs/Suffices_to_Show" }
      ]
    },
    "Next_Step": {
      "description": "the next proof operation to perform. You may yield the generation and await proof state update from user",
      "anyOf": [
        { "enum": ["yield and await proof state", "finished"],
          "type": "string"
        },
        { "$ref": "#/$defs/Have" },
        { "$ref": "#/$defs/Obtain" },
        { "$ref": "#/$defs/Branch" },
        { "$ref": "#/$defs/CaseAnalysis" },
        { "$ref": "#/$defs/Induction" },
        { "$ref": "#/$defs/Rewrite" },
        { "$ref": "#/$defs/Unfold" },
        { "$ref": "#/$defs/Witness" },
        { "$ref": "#/$defs/InferenceRule" },
        { "$ref": "#/$defs/Suffices_to_Show" }
      ]
    },
    "Must_Yield": {
      "description": "You must yield the generation and await proof state update from user",
      "const": "yield and await proof state",
      "type": "string"
    },
    "Thought": {
      "description": "A brief thought that justifies the chosen operation",
      "type": "string"
    }
  },
  "$ref": "#/$defs/Operation"
}