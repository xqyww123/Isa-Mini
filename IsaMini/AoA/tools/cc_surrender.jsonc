{
  "type": "object",
  "properties": {
    "reason": {
      "type": "string",
      "enum": ["refute", "surrender"],
      "description": "Why the proof cannot be completed: 'refute' if the goal appears to be buggy or unprovable from the given premises (explain what is missing or wrong), 'surrender' if no viable strategy remains but the goal may still be provable"
    },
    "detail": { "type": "string" }
  },
  "required": ["reason", "detail"],
  "additionalProperties": false
}
