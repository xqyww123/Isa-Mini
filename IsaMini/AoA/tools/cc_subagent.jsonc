{
  "type": "object",
  "properties": {
    "step_id": {
      "type": "string",
      "description": "The target step that the sub-agent aims to prove."
    },
    "suggestions": {
      "type": "string",
      "description": "Strategy hints and proof suggestions for the sub-agent. Refer to facts by name (and list them in `helpful_lemmas`); do not cite step ids — the sub-agent cannot see steps outside its own goal."
    },
    "helpful_lemmas": {
      "type": "array",
      "items": { "type": "string", "description": "name" },
      "description": "The more the better; list any that might help"
    }
  },
  "required": ["step_id", "suggestions", "helpful_lemmas"],
  "additionalProperties": false
}
